{
  "name": "tanban",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/platform-web",
    "apps/merchant-web",
    "apps/customer-miniapp"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "npm run dev:prototype",
    "dev:prototype": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "dev:platform": "npm run dev --workspace @tanban/platform-web",
    "dev:merchant": "npm run dev --workspace @tanban/merchant-web",
    "build": "npm run build:prototype && npm run build:platform && npm run build:merchant && npm run typecheck:miniapp",
    "build:prototype": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:platform": "npm run build --workspace @tanban/platform-web",
    "build:merchant": "npm run build --workspace @tanban/merchant-web",
    "typecheck:miniapp": "npm run typecheck --workspace @tanban/customer-miniapp",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs && npm run test --workspaces --if-present",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "overrides": {
    "path-to-regexp": "8.4.0",
    "postcss": "8.5.10"
  },
  "type": "module"
}

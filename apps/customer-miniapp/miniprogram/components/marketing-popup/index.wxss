.marketing-popup-mask { position: fixed; top: 0; right: 0; bottom: 0; left: 0; z-index: 120; display: flex; align-items: center; justify-content: center; box-sizing: border-box; padding: 54rpx; background: rgba(20,14,11,.72); }
.marketing-popup-card { position: relative; width: 100%; max-width: 650rpx; overflow: hidden; border-radius: 32rpx; background: #fffefa; box-shadow: 0 34rpx 100rpx rgba(0,0,0,.32); }
.marketing-popup-image { display: block; width: 100%; height: 720rpx; background: #eee4da; }
.marketing-popup-close { position: absolute; top: 22rpx; right: 22rpx; z-index: 3; width: 58rpx; height: 58rpx; margin: 0; padding: 0; border: 0; border-radius: 50%; color: #fff; background: rgba(0,0,0,.45); font-size: 38rpx; line-height: 54rpx; }
.marketing-popup-copy { position: absolute; right: 0; bottom: 0; left: 0; display: flex; flex-direction: column; gap: 9rpx; padding: 100rpx 34rpx 42rpx; color: #fff; background: linear-gradient(transparent, rgba(20,10,6,.78)); }
.marketing-popup-copy text:first-child { font-size: 39rpx; font-weight: 900; }
.marketing-popup-copy text:last-child { font-size: 23rpx; }
.marketing-popup-action { position: absolute; right: 30rpx; bottom: 30rpx; z-index: 2; margin: 0; padding: 0 28rpx; border: 0; border-radius: 999rpx; color: #3d2c22; background: #f8d36d; font-size: 23rpx; font-weight: 800; }

<view class="page lottery-page">
  <view class="lottery-heading" wx:if="{{selected}}"><text>{{selected.name}}</text><text>{{selected.description || '免费参与，看看今天的手气'}}</text></view>
  <scroll-view class="campaign-tabs" scroll-x wx:if="{{campaigns.length > 1}}"><button class="{{selected.id === item.id ? 'active' : ''}}" wx:for="{{campaigns}}" wx:key="id" data-id="{{item.id}}" bindtap="chooseCampaign">{{item.name}}</button></scroll-view>
  <view class="lottery-board" wx:if="{{selected}}">
    <view class="prize-grid">
      <view class="prize-card" wx:for="{{selected.prizes}}" wx:key="id"><text class="prize-symbol">{{item.prize_type === 'COUPON' ? '券' : '好运'}}</text><text class="prize-name">{{item.name}}</text><text class="prize-stock">{{item.stockText}}</text></view>
    </view>
    <button class="draw-button" loading="{{drawing}}" disabled="{{drawing}}" bindtap="draw">{{drawing ? '正在开奖' : '立即抽奖'}}</button>
    <text class="draw-limit">每日 {{selected.daily_limit}} 次 · 每人最多 {{selected.total_limit}} 次</text>
  </view>
  <view class="lottery-terms card" wx:if="{{selected}}"><text>活动规则</text><text>{{selected.terms || '本活动免费参与，奖品数量有限。优惠券正式抵扣需完成微信顾客登录与订单计价闭环。'}}</text></view>
  <view class="empty" wx:elif="{{loading}}">正在准备抽奖活动…</view>
  <view class="empty" wx:elif="{{error}}"><text>{{error}}</text><button bindtap="loadCampaigns">重新加载</button></view>
  <view class="empty" wx:else><text>暂时没有进行中的抽奖</text><button bindtap="goCoupons">去领优惠券</button></view>
</view>

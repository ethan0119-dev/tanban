.lottery-page { min-height: 100vh; padding: 36rpx 28rpx 60rpx; background: var(--green); box-sizing: border-box; }
.lottery-heading { display: flex; flex-direction: column; align-items: center; gap: 12rpx; padding: 18rpx 20rpx 28rpx; color: var(--on-primary); text-align: center; }
.lottery-heading text:first-child { font-size: 48rpx; font-weight: var(--font-weight-semibold); }
.lottery-heading text:last-child { font-size: 25rpx; opacity: .8; }
.campaign-tabs { margin-bottom: 20rpx; white-space: nowrap; }
.campaign-tabs button { display: inline-block; margin-right: 12rpx; padding: 0 24rpx; border: 1rpx solid var(--on-primary); border-radius: 999rpx; color: var(--on-primary); background: transparent; font-size: 24rpx; line-height: 62rpx; }
.campaign-tabs button.active { color: var(--on-accent); background: var(--lime); }
.lottery-board { padding: 24rpx; border: 8rpx solid var(--lime); border-radius: 40rpx; background: var(--surface); box-shadow: var(--card-shadow); }
.prize-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.prize-card { min-height: 154rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 7rpx; padding: 18rpx; border: 1rpx solid var(--card-border); border-radius: var(--radius); color: var(--ink); background: var(--soft-primary); text-align: center; }
.prize-card .prize-symbol { width: 45rpx; height: 45rpx; border-radius: 50%; color: var(--on-primary); background: var(--green); font-size: 22rpx; line-height: 45rpx; }
.prize-card .prize-name { font-size: 27rpx; font-weight: var(--font-weight-semibold); }
.prize-card .prize-stock { color: var(--muted); font-size: 22rpx; }
.draw-button { width: 72%; margin: 30rpx auto 12rpx; border-radius: var(--button-radius); color: var(--on-accent); background: var(--lime); font-size: 34rpx; font-weight: var(--font-weight-semibold); line-height: 86rpx; }
.draw-limit { display: block; color: var(--on-primary); font-size: 22rpx; text-align: center; opacity: .8; }
.lottery-terms { display: flex; flex-direction: column; gap: 14rpx; margin: 26rpx 0 0; color: var(--muted); line-height: 1.7; }
.lottery-terms text:first-child { color: var(--ink); font-weight: var(--font-weight-semibold); }
.lottery-page .empty { color: var(--on-primary); opacity: .82; }
.activity-action { display: flex; align-items: center; justify-content: center; width: 240rpx; height: 72rpx; min-height: 72rpx; margin: 26rpx auto 0; padding: 0 24rpx; border-radius: var(--button-radius); background: var(--lime); color: var(--on-accent); box-sizing: border-box; font-size: var(--font-body); font-weight: var(--font-weight-semibold); line-height: 1; }

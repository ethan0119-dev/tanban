.menu-page { display: grid; grid-template-columns: 170rpx 1fr; grid-template-rows: 84rpx 1fr; height: 100vh; padding-bottom: 112rpx; box-sizing: border-box; background: var(--surface); }
.menu-page.store-closed { grid-template-rows: 84rpx 82rpx 1fr; }
.order-mode-bar { grid-column: 1 / -1; display: flex; align-items: stretch; justify-content: center; gap: 48rpx; padding: 0 42rpx; background: var(--surface, #fffefa); border-bottom: 1rpx solid var(--line); }
.order-mode-bar view { display: flex; align-items: center; justify-content: center; min-width: 118rpx; padding: 0 10rpx; border-bottom: 5rpx solid transparent; border-radius: 0; color: var(--ink); box-sizing: border-box; font-size: var(--font-body); text-align: center; }
.order-mode-bar .active { color: var(--green); background: transparent; border-bottom-color: var(--green); font-weight: 800; }
.order-mode-bar .disabled { color: var(--disabled-text); background: transparent; }
.menu-closed-banner { grid-column: 1 / -1; display: flex; align-items: center; justify-content: space-between; gap: 18rpx; padding: 15rpx 26rpx; color: var(--ink); background: var(--surface); border-bottom: 1rpx solid var(--line); box-sizing: border-box; }
.closed-summary { display: flex; align-items: center; min-width: 0; }
.closed-summary > text:last-child { padding-left: 18rpx; color: var(--ink); font-size: 23rpx; }
.closed-label { padding-left: 18rpx; padding-right: 18rpx; border-left: 6rpx solid var(--green); border-right: 1rpx solid var(--line); color: var(--green); font-size: 24rpx; font-weight: 900; }
.closed-next { flex: none; color: var(--green); font-size: 22rpx; font-weight: 700; }
.categories { height: 100%; background: var(--paper); border-right: 1rpx solid var(--line); box-sizing: border-box; }
.category { min-height: 88rpx; padding: 28rpx 18rpx; border-left: 6rpx solid transparent; box-sizing: border-box; color: var(--muted); font-size: var(--font-body); text-align: left; }
.category.active { border-left-color: var(--green); background: var(--surface, #fffefa); color: var(--green); font-weight: 800; }
.products { height: 100%; background: var(--surface, #fffefa); }
.menu-title { display: flex; justify-content: space-between; padding: 32rpx 28rpx 12rpx; font-size: var(--font-subtitle); font-weight: 800; }
.menu-title > view { display: flex; flex-direction: column; gap: 8rpx; }
.table-inline { align-self: flex-start; padding: 5rpx 12rpx; border-radius: 999rpx; background: var(--soft-primary); color: var(--green); font-size: 19rpx; font-weight: 700; }
.fast-food-inline { align-self: flex-start; padding: 5rpx 12rpx; border-radius: 999rpx; color: #a35f27; background: #fff1dd; font-size: 19rpx; font-weight: 700; }
.menu-title .muted { font-size: 22rpx; font-weight: 400; }
.recommended-section { padding: 26rpx 0 12rpx; border-bottom: 1rpx solid var(--line); background: var(--surface); }
.recommended-heading { display: flex; align-items: baseline; justify-content: space-between; padding: 0 26rpx 18rpx; }
.recommended-heading text:first-child { color: var(--ink); font-size: var(--font-subtitle); font-weight: 900; }
.recommended-heading text:last-child { color: var(--muted); font-size: var(--font-caption); }
.recommended-scroll { width: 100%; white-space: nowrap; }
.recommended-track { display: inline-flex; gap: 16rpx; padding: 0 26rpx 12rpx; }
.recommended-card { display: inline-flex; width: 224rpx; flex-direction: column; gap: 11rpx; padding-bottom: 16rpx; overflow: hidden; border: 1rpx solid var(--card-border); border-radius: var(--radius); background: var(--surface); box-shadow: var(--card-shadow); }
.recommended-image-wrap { position: relative; width: 224rpx; height: 190rpx; }
.recommended-image-wrap image { width: 100%; height: 100%; }
.recommended-image-wrap > text { position: absolute; top: 10rpx; left: 10rpx; padding: 5rpx 12rpx; border-radius: 8rpx; background: var(--green); color: var(--on-primary); font-size: 19rpx; font-weight: 800; }
.recommended-name { padding: 0 15rpx; overflow: hidden; color: var(--ink); font-size: 24rpx; font-weight: 800; text-overflow: ellipsis; white-space: nowrap; }
.recommended-card > view:last-child { display: flex; align-items: center; justify-content: space-between; padding: 0 14rpx; }
.recommended-card .price { color: var(--ink); font-size: 25rpx; font-weight: 900; }
.recommended-card button { min-width: 52rpx; height: 52rpx; margin: 0; padding: 0 15rpx; border-radius: var(--button-radius); background: var(--green); color: var(--on-primary); font-size: 20rpx; line-height: 52rpx; }
.recommended-card button[disabled] { background: var(--disabled-bg); color: var(--disabled-text); }
.product { position: relative; display: grid; grid-template-columns: 150rpx minmax(0, 1fr); gap: 20rpx; align-items: center; margin: 0 26rpx; padding: 26rpx 0; border-bottom: 1rpx solid var(--line); }
.density-compact .product { grid-template-columns: 118rpx minmax(0, 1fr); gap: 14rpx; padding: 17rpx 0; }
.product-image { width: 150rpx; height: 150rpx; border-radius: var(--radius, 22rpx); }
.density-compact .product-image { width: 118rpx; height: 118rpx; }
.fallback-image { object-fit: contain; background: #f3efe7; opacity: .74; }
.product-main { display: flex; min-width: 0; flex-direction: column; gap: 10rpx; }
.product-name { display: block; overflow: hidden; font-size: var(--font-subtitle); font-weight: 800; line-height: 1.35; text-overflow: ellipsis; white-space: nowrap; }
.product-desc { overflow: hidden; color: var(--muted); font-size: var(--font-caption); text-overflow: ellipsis; white-space: nowrap; }
.product-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 12rpx; color: var(--muted); font-size: var(--font-caption); }
.product-purchase { display: flex; align-items: center; justify-content: space-between; min-height: 54rpx; }
.product-purchase > text { color: var(--muted); font-size: 20rpx; }
.product-action { display: flex; flex: none; align-items: center; margin-left: auto; }
.product-action button { display: flex; align-items: center; justify-content: center; gap: 8rpx; min-width: 56rpx; height: 56rpx; margin: 0; padding: 0; border: 1rpx solid var(--green); border-radius: var(--button-radius); background: var(--green); color: var(--on-primary); line-height: 1; }
.product-action button.with-text { width: auto; min-width: 126rpx; padding: 0 18rpx; font-size: 21rpx; }
.product-action button[disabled], .cart-bar button[disabled] { color: var(--disabled-text); background: var(--surface); border-color: var(--disabled-border); }
.selected-skus { display: flex; flex-direction: column; gap: 10rpx; margin-top: 8rpx; }
.selected-sku { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; padding: 9rpx 12rpx; border-radius: 12rpx; background: var(--paper); color: var(--muted); font-size: 21rpx; }
.line-stepper { display: flex; align-items: center; gap: 10rpx; }
.line-stepper button { width: 40rpx; height: 40rpx; margin: 0; padding: 0; border: 1rpx solid rgba(120,120,120,.3); border-radius: 50%; background: var(--surface, white); font-size: 24rpx; line-height: 38rpx; }
.sold-out { color: #aaa; font-size: 22rpx; }
.category-top { grid-template-columns: 1fr; grid-template-rows: 84rpx 92rpx 1fr; }
.category-top.store-closed { grid-template-rows: 84rpx 82rpx 92rpx 1fr; }
.category-top .categories { display: block; width: 100%; height: 92rpx; white-space: nowrap; background: var(--surface, #fffefa); border-bottom: 1rpx solid rgba(120,120,120,.14); }
.category-top .category { display: inline-block; padding: 27rpx 30rpx 23rpx; }
.category-top .category.active { border-left: 0; border-bottom: 6rpx solid var(--green); }
.product-grid-view .product-list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; padding: 18rpx 24rpx 150rpx; }
.product-grid-view .product { display: flex; flex-direction: column; align-items: stretch; gap: 12rpx; margin: 0; padding: 0 0 18rpx; overflow: hidden; border: 1rpx solid var(--card-border); border-radius: var(--radius, 22rpx); background: var(--surface, #fffefa); box-shadow: var(--card-shadow); }
.product-grid-view .product-image { width: 100%; height: 230rpx; border-radius: 0; }
.product-grid-view .product-main { padding: 0 18rpx; }
.product-grid-view .product-purchase { margin-top: auto; }
.product-grid-view .selected-skus { display: none; }
.cart-bar { position: fixed; right: 0; bottom: 0; left: 0; z-index: 10; display: flex; align-items: center; justify-content: space-between; min-height: 104rpx; padding: 12rpx 22rpx 12rpx 28rpx; border-top: 1rpx solid var(--line); border-radius: 0; background: var(--surface); color: var(--ink); box-shadow: 0 -6rpx 20rpx rgba(23,32,27,.08); }
.cart-bar .cart-summary { display: flex; flex: 1; min-width: 0; align-items: baseline; gap: 14rpx; font-size: 21rpx; color: var(--muted); }
.cart-count { display: flex; align-items: center; justify-content: center; width: 42rpx; height: 42rpx; border: 1rpx solid var(--green); border-radius: 50%; background: var(--surface); color: var(--green); font-weight: 800; }
.cart-price { color: var(--ink); font-size: 34rpx; font-weight: 800; }
.cart-action { display: flex; flex: 0 0 238rpx; flex-direction: column; align-items: stretch; gap: 5rpx; margin-left: 18rpx; text-align: center; }
.cart-action > text { color: var(--muted); font-size: 17rpx; }
.cart-bar button { display: flex; align-items: center; justify-content: center; width: 100%; height: 62rpx; min-height: 62rpx; margin: 0; padding: 0 22rpx; border: 1rpx solid var(--green); border-radius: var(--button-radius); background: var(--green); color: var(--on-primary); box-sizing: border-box; font-size: var(--font-body); font-weight: 800; line-height: 1; }
.cart-bar button[disabled] { background: var(--disabled-bg); }
.dine-in-scan-mask { position: fixed; top: 0; right: 0; bottom: 0; left: 0; z-index: 40; display: flex; align-items: flex-end; background: rgba(18, 20, 18, .42); }
.dine-in-scan-sheet { position: relative; width: 100%; padding: 20rpx 32rpx calc(30rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid var(--line); border-radius: 28rpx 28rpx 0 0; background: var(--surface); box-shadow: 0 -18rpx 58rpx rgba(23,32,27,.14); box-sizing: border-box; }
.sheet-handle { width: 68rpx; height: 7rpx; margin: 0 auto 20rpx; border-radius: 99rpx; background: var(--disabled-border); }
.scan-sheet-heading { display: flex; align-items: center; justify-content: center; margin-bottom: 24rpx; }
.scan-sheet-heading > text { color: var(--ink); font-size: 34rpx; font-weight: 900; }
.scan-sheet-heading > view { position: absolute; top: 42rpx; right: 30rpx; display: flex; align-items: center; justify-content: center; width: 52rpx; height: 52rpx; }
.scan-sheet-main { display: grid; grid-template-columns: 190rpx minmax(0, 1fr); gap: 28rpx; align-items: center; }
.scan-visual { display: flex; align-items: center; justify-content: center; height: 190rpx; border: 1rpx solid var(--line); border-radius: calc(var(--radius, 24rpx) * .65); background: var(--paper); }
.scan-visual image { width: 116rpx; height: 116rpx; }
.scan-copy { display: flex; min-width: 0; flex-direction: column; gap: 13rpx; }
.scan-title { color: var(--ink); font-size: 27rpx; font-weight: 800; }
.scan-description { color: var(--muted); font-size: 20rpx; line-height: 1.5; }
.scan-copy button { display: flex; align-items: center; justify-content: center; width: 100%; min-height: 64rpx; margin: 0; padding: 0 18rpx; border-radius: var(--button-radius); box-sizing: border-box; font-size: 23rpx; font-weight: 800; line-height: 1; }
.scan-primary { border: 1rpx solid var(--green); background: var(--green); color: var(--on-primary); }
.scan-secondary { border: 1rpx solid var(--green); background: var(--surface); color: var(--green); }
.scan-steps { display: block; margin-top: 28rpx; color: var(--muted); font-size: 20rpx; text-align: center; }
.scan-back { display: block; margin: 16rpx auto 0; padding: 0 20rpx; background: transparent; color: var(--green); font-size: 22rpx; line-height: 56rpx; }
.sku-mask { position: fixed; top: 0; right: 0; bottom: 0; left: 0; z-index: 30; display: flex; align-items: flex-end; background: rgba(18, 26, 22, .48); }
.sku-picker { width: 100%; max-height: 82vh; padding: 30rpx 28rpx calc(24rpx + env(safe-area-inset-bottom)); border-radius: 30rpx 30rpx 0 0; background: var(--surface, #fffefa); box-sizing: border-box; }
.sku-picker-title { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 24rpx; }
.sku-picker-title > view { display: flex; flex-direction: column; gap: 6rpx; }
.sku-picker-title > view text:first-child { font-size: 31rpx; font-weight: 800; }
.sku-picker-title > view text:last-child { color: var(--muted); font-size: 22rpx; }
.sku-picker-title button { width: 52rpx; height: 52rpx; margin: 0; padding: 0; border-radius: 50%; background: var(--paper); color: var(--ink); line-height: 52rpx; }
.sku-option { display: flex; align-items: center; justify-content: space-between; width: 100%; margin: 14rpx 0 0; padding: 22rpx 24rpx; border: 2rpx solid rgba(120,120,120,.2); border-radius: 18rpx; background: var(--surface, white); font-size: 26rpx; }
.sku-option text:last-child { color: var(--green); font-weight: 800; }
.configuration-scroll { max-height: 56vh; }
.product-gallery { width: 100%; height: 330rpx; margin-bottom: 22rpx; overflow: hidden; border-radius: 22rpx; background: var(--paper); }
.product-gallery image { width: 100%; height: 100%; display: block; }
.configuration-group { padding: 12rpx 0 22rpx; border-bottom: 1rpx solid rgba(120,120,120,.12); }
.configuration-heading { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 14rpx; }
.configuration-heading text:first-child { color: var(--ink); font-size: 27rpx; font-weight: 800; }
.configuration-heading text:last-child { color: var(--muted); font-size: 20rpx; }
.configuration-options { display: flex; flex-wrap: wrap; justify-content: space-between; }
.configuration-option-cell { flex: 0 0 48.5%; width: 48.5%; min-width: 0; margin-bottom: 12rpx; box-sizing: border-box; }
.configuration-option { display: flex; align-items: center; justify-content: space-between; width: 100%; max-width: 100%; min-width: 0; min-height: 70rpx; margin: 0; padding: 10rpx 18rpx; overflow: hidden; border: 2rpx solid rgba(120,120,120,.18); border-radius: 16rpx; background: var(--surface, white); color: var(--ink); box-sizing: border-box; font-size: 23rpx; line-height: 1.3; }
.configuration-option text:first-child { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.configuration-option text:last-child { flex: none; margin-left: 12rpx; color: var(--green); font-size: 20rpx; }
.configuration-option.selected { border-color: var(--green); background: var(--green); color: var(--on-primary); box-shadow: none; }
.configuration-option.selected text:last-child { color: var(--on-primary); }
.configuration-confirm { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; padding-top: 22rpx; }
.configuration-confirm > view { display: flex; flex-direction: column; color: var(--muted); font-size: 20rpx; }
.configuration-price { color: var(--ink); font-size: 34rpx; font-weight: 800; }
.configuration-confirm button { display: flex; flex: 1; align-items: center; justify-content: center; max-width: 330rpx; min-height: 72rpx; margin: 0; padding: 0 24rpx; border-radius: var(--button-radius); background: var(--green); color: var(--on-primary); box-sizing: border-box; font-weight: 800; line-height: 1.2; }

<view class="page menu-page {{menuLayoutClass}} {{store && store.businessStatus !== 'OPEN' ? 'store-closed' : ''}}" style="{{appearanceStyle}}" wx:if="{{!loading && !routeError}}">
  <view class="menu-overview">
    <view class="menu-store-row">
      <view class="menu-store-identity">
        <image src="/assets/icons/star.png" mode="aspectFit" />
        <view><text>{{store.name}}</text><text>{{store.address || '欢迎光临，现点现做'}}</text></view>
      </view>
      <view class="order-mode-bar"><view class="{{orderMode === 'DINE_IN' ? 'active' : ''}}" data-mode="DINE_IN" bindtap="chooseMode">堂食</view><view class="{{orderMode === 'TAKEOUT' ? 'active' : ''}}" data-mode="TAKEOUT" bindtap="chooseMode">自取</view><view class="disabled" data-mode="DELIVERY" bindtap="chooseMode">外卖</view></view>
    </view>
    <view class="menu-notice-row">
      <view><image src="/assets/icons/file-text.png" mode="aspectFit" /><text>{{store.theme.announcement || '商家暂无公告'}}</text></view>
      <button bindtap="showStoreInfo">更多</button>
    </view>
    <view class="menu-closed-banner" wx:if="{{store && store.businessStatus !== 'OPEN'}}"><view class="closed-summary"><text class="closed-label">暂停接单</text><text>门店休息中</text></view><text class="closed-next" wx:if="{{nextOpenLabel}}">{{nextOpenLabel}}</text></view>
  </view>
  <view class="recommended-section" wx:if="{{recommendedProducts.length}}">
    <scroll-view class="recommended-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="recommended-track">
        <view class="recommended-card" wx:for="{{recommendedProducts}}" wx:key="id">
          <view class="recommended-image-wrap"><image src="{{item.imageUrl || '/assets/tanban-product-fallback.png'}}" mode="aspectFill" /><text>推荐</text></view>
          <text class="recommended-name">{{item.name}}</text>
          <view class="recommended-card-footer"><text class="price">¥{{item.price / 100}}</text><button class="{{item.requiresConfiguration ? 'with-text' : 'icon-only'}}" disabled="{{item.soldOut || (store && store.businessStatus !== 'OPEN')}}" data-id="{{item.id}}" bindtap="addProduct">{{item.requiresConfiguration ? '选择' : '＋'}}</button></view>
        </view>
      </view>
    </scroll-view>
  </view>
  <view class="menu-catalog">
  <scroll-view class="categories" scroll-y="{{decoration.menu.categoryLayout === 'LEFT'}}" scroll-x="{{decoration.menu.categoryLayout === 'TOP'}}" enhanced>
    <view wx:if="{{decoration.menu.loadMode === 'ALL'}}" class="category {{activeCategoryId === 0 ? 'active' : ''}}" data-id="0" bindtap="chooseCategory">全部</view>
    <view wx:for="{{categories}}" wx:key="id" class="category {{activeCategoryId === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="chooseCategory">{{item.name}}</view>
  </scroll-view>
  <scroll-view class="products" scroll-y enhanced>
    <view class="menu-title"><view><text>今晚菜单</text><text class="table-inline" wx:if="{{tableContext}}">堂食 · {{tableContext.tableName}}</text><text class="fast-food-inline" wx:elif="{{fastFoodContext}}">快餐 · {{fastFoodContext.plateName}}</text></view><text class="muted">现点现做</text></view>
    <view class="product-list">
      <view class="product" wx:for="{{products}}" wx:key="id" wx:if="{{activeCategoryId === 0 || item.categoryId === activeCategoryId}}">
        <image class="product-image {{!item.imageUrl ? 'fallback-image' : ''}}" src="{{item.imageUrl || '/assets/tanban-product-fallback.png'}}" mode="aspectFill" />
        <view class="product-main">
          <text class="product-name">{{item.name}}</text>
          <text class="product-desc" wx:if="{{decoration.menu.showDescription}}">{{item.description || '用心制作，口味可选'}}</text>
          <view class="product-meta"><text class="price">¥{{item.price / 100}}</text><text wx:if="{{decoration.menu.showStock}}">库存 {{item.stock}}</text><text wx:if="{{decoration.menu.showSales && item.sales !== undefined}}">已售 {{item.sales}}</text></view>
          <view class="selected-skus" wx:if="{{item.selectedItems.length}}">
            <view class="selected-sku" wx:for="{{item.selectedItems}}" wx:for-item="selected" wx:key="lineKey">
              <text>{{selected.optionSummary || selected.skuName || '默认规格'}}</text>
              <view class="line-stepper">
                <button data-line-key="{{selected.lineKey}}" bindtap="decreaseCartItem">−</button>
                <text>{{selected.quantity}}</text>
                <button data-line-key="{{selected.lineKey}}" bindtap="incrementCartItem">＋</button>
              </view>
            </view>
          </view>
          <view class="product-purchase">
            <text wx:if="{{item.selectedQuantity}}">已选 {{item.selectedQuantity}}</text>
            <view class="product-action" wx:if="{{!item.soldOut}}"><button disabled="{{store && store.businessStatus !== 'OPEN'}}" class="plus {{item.requiresConfiguration || (store && store.businessStatus !== 'OPEN') ? 'with-text' : 'icon-only'}}" data-id="{{item.id}}" bindtap="addProduct"><icon wx:if="{{store && store.businessStatus !== 'OPEN'}}" type="cancel" size="14" color="#77736e"/><text>{{store && store.businessStatus !== 'OPEN' ? '暂停' : (item.requiresConfiguration ? '选规格/口味' : '＋')}}</text></button></view>
            <text wx:else class="sold-out">售罄</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
  </view>
  <view class="cart-bar"><view class="cart-summary {{cartQuantity ? 'can-open' : ''}}" role="button" aria-label="查看购物车" bindtap="showCart"><text class="cart-count">{{cartQuantity}}</text><text class="cart-price">¥{{cartAmount / 100}}</text><text>已选 {{cartQuantity}} 件</text><text class="cart-expand" wx:if="{{cartQuantity}}">查看</text></view><view class="cart-action"><button disabled="{{store && store.businessStatus !== 'OPEN'}}" bindtap="checkout">去结算</button><text wx:if="{{store && store.businessStatus !== 'OPEN'}}">门店休息中，暂不可下单</text></view></view>
</view>
<view class="empty" wx:elif="{{routeError}}"><text>{{routeError}}</text><text>请重新扫描有效二维码</text></view>
<view class="empty" wx:else>正在准备菜单…</view>
<view class="cart-sheet-mask" style="{{appearanceStyle}}" wx:if="{{cartVisible}}" bindtap="closeCart">
  <view class="cart-sheet" catchtap="noop">
    <view class="cart-sheet-handle" />
    <view class="cart-sheet-header"><view><text>购物车</text><text>共 {{cartQuantity}} 件</text></view><button aria-label="关闭购物车" bindtap="closeCart">×</button></view>
    <scroll-view class="cart-sheet-list" scroll-y enhanced>
      <view class="cart-sheet-item" wx:for="{{cart}}" wx:key="lineKey">
        <view class="cart-item-copy"><text>{{item.name}}</text><text>{{item.optionSummary || item.skuName || '默认规格'}}</text></view>
        <view class="cart-item-control">
          <text>¥{{item.price * item.quantity / 100}}</text>
          <view class="cart-sheet-stepper">
            <button aria-label="减少一份" data-line-key="{{item.lineKey}}" bindtap="decreaseCartItem">−</button>
            <text>{{item.quantity}}</text>
            <button aria-label="增加一份" data-line-key="{{item.lineKey}}" bindtap="incrementCartItem">＋</button>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
<view class="dine-in-scan-mask" style="{{appearanceStyle}}" wx:if="{{dineInScanPromptVisible}}" bindtap="closeDineInScanPrompt">
  <view class="dine-in-scan-sheet" catchtap="noop">
    <view class="sheet-handle" />
    <view class="scan-sheet-heading"><text>先确认桌号</text><view role="button" aria-label="关闭堂食扫码" bindtap="closeDineInScanPrompt"><icon type="clear" size="24" color="#77736e" /></view></view>
    <view class="scan-sheet-main">
      <view class="scan-visual"><image src="/assets/icons/qr-scan-2-line.svg" mode="aspectFit" /></view>
      <view class="scan-copy">
        <text class="scan-title">请扫描桌上的桌码</text>
        <text class="scan-description">识别成功后会显示桌号，再进入堂食菜单</text>
        <button class="scan-primary" loading="{{scanInProgress}}" disabled="{{scanInProgress}}" bindtap="startDineInScan">打开扫一扫</button>
        <button class="scan-secondary" bindtap="showTableScanHelp">查看扫码示例</button>
      </view>
    </view>
    <text class="scan-steps">扫码　·　确认桌号　·　开始点单</text>
    <button class="scan-back" bindtap="closeDineInScanPrompt">没有桌码？返回自取</button>
  </view>
</view>
<view class="sku-mask" style="{{appearanceStyle}}" wx:if="{{selectingProduct}}" bindtap="closeSkuPicker">
  <view class="sku-picker" catchtap="noop">
    <view class="sku-picker-title"><view><text>选择规格与口味</text><text>{{selectingProduct.name}}</text></view><button bindtap="closeSkuPicker">×</button></view>
    <scroll-view class="configuration-scroll" scroll-y enhanced>
      <swiper class="product-gallery" wx:if="{{selectingProduct.images && selectingProduct.images.length}}" indicator-dots="{{selectingProduct.images.length > 1}}" circular="{{selectingProduct.images.length > 1}}" autoplay="{{false}}">
        <swiper-item wx:for="{{selectingProduct.images}}" wx:key="url">
          <image src="{{item.url}}" mode="aspectFill" aria-label="{{selectingProduct.name}}商品图片" />
        </swiper-item>
      </swiper>
      <view class="configuration-group" wx:if="{{selectableSkus.length > 1}}">
        <view class="configuration-heading"><text>规格</text><text>请选择 1 项</text></view>
        <view class="configuration-options">
          <view class="configuration-option-cell" wx:for="{{selectableSkus}}" wx:key="id">
            <button class="configuration-option {{selectedSkuId === item.id ? 'selected' : ''}}" data-sku-id="{{item.id}}" bindtap="chooseSku"><text>{{item.name}}</text><text>¥{{item.price / 100}}</text></button>
          </view>
        </view>
      </view>
      <view class="configuration-group" wx:for="{{pickerOptionGroups}}" wx:for-item="group" wx:key="id">
        <view class="configuration-heading"><text>{{group.name}}</text><text>{{group.minSelect > 0 ? '必选' : '可选'}} · {{group.selectionMode === 'SINGLE' ? '单选' : '多选'}} {{group.minSelect}}–{{group.maxSelect}} 项</text></view>
        <view class="configuration-options">
          <view class="configuration-option-cell" wx:for="{{group.values}}" wx:for-item="value" wx:key="id">
            <button class="configuration-option {{value.selected ? 'selected' : ''}}" data-group-id="{{group.id}}" data-value-id="{{value.id}}" bindtap="toggleOption"><text>{{value.name}}</text><text wx:if="{{value.priceDeltaCents}}">+¥{{value.priceDeltaCents / 100}}</text></button>
          </view>
        </view>
      </view>
      <view class="configuration-group" wx:for="{{pickerModifierGroups}}" wx:for-item="group" wx:key="id">
        <view class="configuration-heading"><text>{{group.name}}</text><text>{{group.minSelect > 0 ? '必选' : '可选'}} · 最多{{group.maxSelect}}项</text></view>
        <view class="configuration-options">
          <view class="configuration-option-cell" wx:for="{{group.items}}" wx:for-item="modifier" wx:key="id">
            <button class="configuration-option {{modifier.selected ? 'selected' : ''}}" data-group-id="{{group.id}}" data-item-id="{{modifier.id}}" bindtap="toggleModifier"><text>{{modifier.name}}</text><text wx:if="{{modifier.priceCents}}">+¥{{modifier.priceCents / 100}}</text></button>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="configuration-confirm"><view><text>本份预计</text><text class="configuration-price">¥{{pickerPrice / 100}}</text></view><button bindtap="confirmConfiguredProduct">加入购物车</button></view>
  </view>
</view>
<view class="store-info-mask" style="{{appearanceStyle}}" wx:if="{{storeInfoVisible && store}}" bindtap="closeStoreInfo">
  <view class="store-info-sheet" catchtap="noop">
    <view class="store-info-handle" />
    <view class="store-info-title"><text>{{store.name}}</text><button bindtap="closeStoreInfo">×</button></view>
    <view class="store-info-section"><text>公告</text><text>{{store.theme.announcement || '商家暂无公告'}}</text></view>
    <view class="store-info-section"><text>营业时间</text><text>{{store.businessHoursSummary || store.businessHours || '请电话咨询商家'}}</text></view>
    <view class="store-info-section"><text>门店信息</text><text>联系电话：{{store.phone || store.customerService.phone || '暂未配置'}}</text><text>门店地址：{{store.address || '暂未配置'}}</text></view>
    <view class="store-info-actions">
      <button bindtap="copyAddress">复制地址</button>
      <button wx:if="{{store.location}}" bindtap="openStoreLocation">导航到店</button>
      <button class="primary" bindtap="callStore">联系商家</button>
    </view>
  </view>
</view>
<marketing-popup appearance-style="{{appearanceStyle}}" store-code="{{storeCode}}" placement-code="MENU_POPUP" channel-scope="{{tableContext ? 'DINE_IN' : 'TAKEOUT'}}" />

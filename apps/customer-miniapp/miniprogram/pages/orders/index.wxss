.orders-page { min-height: 100vh; background: var(--paper); }
.primary-tabs { display: flex; align-items: flex-end; justify-content: center; gap: 72rpx; height: 112rpx; background: var(--surface); }
.primary-tabs view { position: relative; padding: 0 4rpx 24rpx; color: var(--muted); font-size: var(--font-subtitle); font-weight: 700; }
.primary-tabs .active { color: var(--ink); font-size: var(--font-title); font-weight: 900; }
.primary-tabs .active::after { position: absolute; right: 0; bottom: 10rpx; left: 0; height: 7rpx; border-radius: 999rpx; background: var(--green); content: ""; }
.scene-tabs { width: 100%; height: 96rpx; white-space: nowrap; background: var(--surface); }
.scene-tab { display: inline-flex; align-items: center; min-width: 92rpx; height: 96rpx; margin: 0 22rpx; box-sizing: border-box; color: var(--muted); font-size: var(--font-body); }
.scene-tab.active { border-bottom: 7rpx solid var(--green); color: var(--ink); font-weight: 900; }
.order-list { display: flex; flex-direction: column; gap: 24rpx; padding: 24rpx 26rpx 46rpx; }
.order-card { padding: 26rpx; border: 1rpx solid var(--card-border); border-radius: var(--radius); background: var(--surface); box-shadow: var(--card-shadow); }
.order-head, .order-head > view, .order-time, .order-summary, .order-foot { display: flex; align-items: center; }
.order-head, .order-time, .order-summary, .order-foot { justify-content: space-between; }
.order-head > view { gap: 12rpx; }
.scene-badge { display: flex; align-items: center; justify-content: center; width: 38rpx; height: 38rpx; border-radius: 8rpx; color: var(--on-primary); background: var(--green); font-size: var(--font-caption); font-weight: 900; }
.scene-badge.dine-in { background: var(--green); }
.store-name { font-size: var(--font-subtitle); font-weight: 900; }
.status-text { color: var(--muted); font-size: var(--font-body); }
.order-time { margin-top: 13rpx; padding-bottom: 22rpx; border-bottom: 1rpx solid var(--line); color: var(--muted); font-size: 22rpx; }
.order-summary { min-height: 116rpx; gap: 24rpx; }
.order-summary > text { min-width: 0; overflow: hidden; color: var(--ink); font-size: 25rpx; text-overflow: ellipsis; white-space: nowrap; }
.order-summary > view { flex: none; display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; color: var(--muted); font-size: 20rpx; }
.order-summary .amount { color: var(--ink); font-size: 34rpx; font-weight: 800; }
.order-foot { padding-top: 20rpx; border-top: 1rpx solid var(--line); color: var(--muted); font-size: 22rpx; }
.order-foot text:last-child { padding: 10rpx 18rpx; border: 1rpx solid var(--line); border-radius: 999rpx; color: var(--ink); }
.empty-order { display: flex; flex-direction: column; align-items: center; gap: 26rpx; }
.empty-order button { width: 270rpx; }

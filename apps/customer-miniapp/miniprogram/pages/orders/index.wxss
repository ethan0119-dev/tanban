.orders-page { min-height: 100vh; background: #f4f4f2; }
.primary-tabs { display: flex; align-items: flex-end; justify-content: center; gap: 72rpx; height: 112rpx; background: white; }
.primary-tabs view { position: relative; padding: 0 4rpx 24rpx; color: #6f7370; font-size: 31rpx; font-weight: 700; }
.primary-tabs .active { color: #111; font-size: 35rpx; font-weight: 900; }
.primary-tabs .active::after { position: absolute; right: 0; bottom: 10rpx; left: 0; height: 7rpx; border-radius: 999rpx; background: #111; content: ""; }
.scene-tabs { width: 100%; height: 96rpx; white-space: nowrap; background: #f8f8f7; }
.scene-tab { display: inline-flex; align-items: center; height: 96rpx; margin: 0 26rpx; box-sizing: border-box; color: #4d514e; font-size: 29rpx; }
.scene-tab.active { border-bottom: 7rpx solid #111; color: #111; font-weight: 900; }
.order-list { display: flex; flex-direction: column; gap: 24rpx; padding: 24rpx 26rpx 46rpx; }
.order-card { padding: 26rpx; border-radius: 24rpx; background: white; box-shadow: 0 8rpx 30rpx rgba(23,32,27,.035); }
.order-head, .order-head > view, .order-time, .order-summary, .order-foot { display: flex; align-items: center; }
.order-head, .order-time, .order-summary, .order-foot { justify-content: space-between; }
.order-head > view { gap: 12rpx; }
.scene-badge { display: flex; align-items: center; justify-content: center; width: 38rpx; height: 38rpx; border-radius: 8rpx; color: white; background: linear-gradient(160deg, #0fcf78, #00a858); font-size: 21rpx; font-weight: 900; }
.scene-badge.dine-in { background: linear-gradient(160deg, #2f6f5c, #204b3e); }
.store-name { font-size: 30rpx; font-weight: 900; }
.status-text { color: #7c827e; font-size: 27rpx; }
.order-time { margin-top: 13rpx; padding-bottom: 22rpx; border-bottom: 1rpx solid #eeeeeb; color: #929691; font-size: 22rpx; }
.order-summary { min-height: 116rpx; gap: 24rpx; }
.order-summary > text { min-width: 0; overflow: hidden; color: #333733; font-size: 25rpx; text-overflow: ellipsis; white-space: nowrap; }
.order-summary > view { flex: none; display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; color: #999d99; font-size: 20rpx; }
.order-summary .amount { color: #111; font-size: 34rpx; font-weight: 800; }
.order-foot { padding-top: 20rpx; border-top: 1rpx solid #eeeeeb; color: #929691; font-size: 22rpx; }
.order-foot text:last-child { padding: 10rpx 18rpx; border: 1rpx solid #dedfdd; border-radius: 999rpx; color: #333; }
.empty-order { display: flex; flex-direction: column; align-items: center; gap: 26rpx; }
.empty-order button { width: 270rpx; }

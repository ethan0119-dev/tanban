.recharge-page { min-height: 100vh; padding: 30rpx 28rpx 70rpx; box-sizing: border-box; background: linear-gradient(180deg, #f0e1ca 0, #f6f5f0 440rpx); }
.balance-card { display: flex; flex-direction: column; gap: 12rpx; padding: 38rpx; border-radius: 32rpx; color: white; background: linear-gradient(145deg, #244f42, #14372d); box-shadow: 0 22rpx 50rpx rgba(31,73,60,.2); }
.balance-card > text:first-child { color: rgba(255,255,255,.72); font-size: 23rpx; }
.balance-card .balance { font-size: 58rpx; font-weight: 900; }
.balance-card > text:last-child { color: rgba(255,255,255,.64); font-size: 21rpx; }
.section-title { display: flex; align-items: baseline; justify-content: space-between; margin: 40rpx 4rpx 20rpx; }
.section-title text:first-child { font-size: 32rpx; font-weight: 900; }
.section-title text:last-child { color: var(--muted); font-size: 21rpx; }
.rule-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18rpx; }
.rule { display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 30rpx 16rpx; border: 2rpx solid transparent; border-radius: 24rpx; background: #fffefa; }
.rule text:first-child { font-size: 36rpx; font-weight: 900; }
.rule text:last-child { color: #a65d37; font-size: 21rpx; }
.rule.selected { border-color: var(--green); box-shadow: 0 12rpx 30rpx rgba(33,77,63,.1); }
.unavailable, .safety { display: flex; flex-direction: column; gap: 14rpx; padding: 28rpx; border-radius: 24rpx; background: #fffefa; }
.unavailable text:first-child, .safety text:first-child { font-size: 29rpx; font-weight: 900; }
.unavailable text:last-child, .safety text:last-child { color: var(--muted); font-size: 22rpx; line-height: 1.7; }
.safety { margin-top: 24rpx; }
.recharge-button { margin-top: 34rpx; }
.recharge-button[disabled] { color: #8d918e; background: #dfe2df; }

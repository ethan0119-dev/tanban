.section-title { display: block; margin-bottom: 26rpx; font-size: 34rpx; font-weight: var(--font-weight-semibold); }
.checkout-closed { display: flex; flex-direction: column; gap: 10rpx; color: var(--on-primary); background: var(--green); }
.checkout-closed .section-title { margin: 0; }
.checkout-closed > text:not(.section-title) { color: rgba(255,255,255,.72); font-size: 22rpx; }
.table-order-card { display: flex; flex-direction: column; gap: 16rpx; border: 2rpx solid var(--green); background: var(--surface); }
.table-order-card > view { display: flex; flex-direction: column; gap: 8rpx; }
.table-order-card .section-title { margin: 0; font-size: 40rpx; }
.table-badge { align-self: flex-start; padding: 6rpx 14rpx; border-radius: 999rpx; background: var(--green); color: var(--on-primary); font-size: 22rpx; font-weight: var(--font-weight-semibold); }
.table-code { align-self: flex-start; padding: 9rpx 18rpx; border-radius: 14rpx; background: var(--soft-primary); color: var(--green); font-weight: var(--font-weight-semibold); }
.fast-food-order-card { display: flex; flex-direction: column; gap: 16rpx; border: 2rpx solid var(--green); background: var(--surface); }
.fast-food-order-card > view { display: flex; flex-direction: column; gap: 8rpx; }
.fast-food-order-card .section-title { margin: 0; font-size: 40rpx; }
.fast-food-badge { align-self: flex-start; padding: 6rpx 14rpx; border-radius: 999rpx; color: var(--on-primary); background: var(--green); font-size: 22rpx; font-weight: var(--font-weight-semibold); }
.fulfillment { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.fulfillment.pickup-only { grid-template-columns: 1fr; margin-bottom: 18rpx; }
.fulfillment-option { width: 100%; display: flex; flex-direction: column; align-items: flex-start; justify-content: center; padding: 22rpx; box-sizing: border-box; border: 2rpx solid var(--line); border-radius: var(--button-radius); background: var(--surface); text-align: left; }
.fulfillment-option.active { border-color: var(--green); background: var(--soft-primary); }
.fulfillment-option.is-locked { opacity: .78; }
.fulfillment-option .fulfillment-title { margin: 0; color: var(--ink); font-size: 28rpx; font-weight: var(--font-weight-semibold); line-height: 1.35; text-align: left; }
.fulfillment-option text:not(.fulfillment-title) { margin-top: 8rpx; color: var(--muted); font-size: 20rpx; font-weight: 400; line-height: 1.4; text-align: left; }
.line { display: flex; justify-content: space-between; padding: 20rpx 0; border-bottom: 1rpx solid var(--line); }
.line > view { display: flex; flex-direction: column; gap: 8rpx; }
.line .muted { font-size: 22rpx; }
.discount-line, .subtotal-line { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 0 0; }
.discount-line > view { display: flex; flex-direction: column; gap: 7rpx; color: var(--green); font-weight: var(--font-weight-semibold); }
.discount-line .muted { font-size: 20rpx; font-weight: 400; }
.discount-line > text { color: var(--green); font-weight: var(--font-weight-strong); }
.discount-line.selectable { cursor: pointer; }
.discount-line .disabled-discount { color: var(--muted); font-weight: 400; }
.coupon-row { border-top: 1rpx solid var(--line); }
.subtotal-line { color: var(--muted); font-size: 22rpx; }
.total { display: flex; align-items: center; justify-content: space-between; padding-top: 28rpx; font-weight: var(--font-weight-semibold); }
.total .price { font-size: 36rpx; }
.order-remark { display: flex; flex-direction: column; gap: 16rpx; }
.order-remark-heading { display: flex; align-items: center; justify-content: space-between; font-weight: var(--font-weight-semibold); }
.order-remark-heading text:last-child { color: var(--muted); font-size: 20rpx; font-weight: 400; }
.order-remark textarea { width: 100%; min-height: 156rpx; max-height: 320rpx; padding: 20rpx 22rpx; box-sizing: border-box; border-radius: var(--button-radius); background: var(--paper); font-size: 25rpx; line-height: 1.65; text-align: left; }
.contact-field { display: grid; grid-template-columns: 90rpx 1fr; gap: 12rpx; align-items: center; }
.contact-field input { padding: 18rpx; border-radius: var(--button-radius); background: var(--paper); font-size: 24rpx; }
.location-hint { color: var(--muted); font-size: 24rpx; line-height: 1.6; }
.pay-footer { position: fixed; right: 0; bottom: 0; left: 0; display: flex; align-items: center; justify-content: space-between; padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom)); background: var(--surface); box-shadow: 0 -10rpx 30rpx rgba(23,32,27,.08); }
.pay-footer > view { display: flex; flex-direction: column; }
.pay-footer .price { font-size: 38rpx; }
.pay-footer button { margin: 0; padding: 5rpx 48rpx; }
.coupon-sheet-mask { position: fixed; z-index: 1200; inset: 0; display: flex; align-items: flex-end; background: rgba(0,0,0,.42); }
.coupon-sheet { width: 100%; max-height: 72vh; padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom)); box-sizing: border-box; border-radius: 32rpx 32rpx 0 0; background: var(--surface); }
.coupon-sheet-header { display: flex; align-items: center; justify-content: space-between; padding-bottom: 22rpx; font-size: 32rpx; font-weight: var(--font-weight-semibold); }
.coupon-sheet-header text:last-child { color: var(--muted); font-size: 24rpx; font-weight: 400; }
.coupon-choice-list { max-height: 48vh; }
.coupon-choice { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; padding: 24rpx 20rpx; border-top: 1rpx solid var(--line); }
.coupon-choice > view { min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }
.coupon-choice > text { flex-shrink: 0; color: var(--green); font-weight: var(--font-weight-semibold); }
.coupon-choice.selected { border-radius: 18rpx; background: var(--soft-primary); }

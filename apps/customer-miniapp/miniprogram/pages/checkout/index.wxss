.section-title { display: block; margin-bottom: 26rpx; font-size: 31rpx; font-weight: 800; }
.table-order-card { display: flex; flex-direction: column; gap: 16rpx; border: 2rpx solid rgba(33, 77, 63, .18); background: linear-gradient(145deg, #fffefa, #edf4ee); }
.table-order-card > view { display: flex; flex-direction: column; gap: 8rpx; }
.table-order-card .section-title { margin: 0; font-size: 40rpx; }
.table-badge { align-self: flex-start; padding: 6rpx 14rpx; border-radius: 999rpx; background: var(--green); color: white; font-size: 20rpx; font-weight: 800; }
.table-code { align-self: flex-start; padding: 9rpx 18rpx; border-radius: 14rpx; background: rgba(33, 77, 63, .1); color: var(--green); font-weight: 800; }
.fulfillment { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.fulfillment.pickup-only { grid-template-columns: 1fr; margin-bottom: 18rpx; }
.fulfillment button { display: flex; flex-direction: column; align-items: flex-start; padding: 22rpx; border: 2rpx solid #e3e1d9; border-radius: 20rpx; background: white; font-weight: 800; }
.fulfillment button.active { border-color: var(--green); background: #edf4ee; }
.fulfillment text { margin-top: 8rpx; color: var(--muted); font-size: 20rpx; font-weight: 400; }
.line { display: flex; justify-content: space-between; padding: 20rpx 0; border-bottom: 1rpx solid #eeeae2; }
.line > view { display: flex; flex-direction: column; gap: 8rpx; }
.line .muted { font-size: 22rpx; }
.total { display: flex; align-items: center; justify-content: space-between; padding-top: 28rpx; font-weight: 800; }
.total .price { font-size: 36rpx; }
.remark { display: grid; grid-template-columns: 90rpx 1fr auto; gap: 12rpx; align-items: center; }
.remark input { padding: 18rpx; border-radius: 16rpx; background: #f4f2ec; font-size: 24rpx; }
.remark .clear-cart { margin: 0; padding: 0 14rpx; background: transparent; color: #a94b45; font-size: 22rpx; line-height: 64rpx; }
.pay-footer { position: fixed; right: 0; bottom: 0; left: 0; display: flex; align-items: center; justify-content: space-between; padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom)); background: #fffefa; box-shadow: 0 -10rpx 30rpx rgba(23,32,27,.08); }
.pay-footer > view { display: flex; flex-direction: column; }
.pay-footer .price { font-size: 38rpx; }
.pay-footer button { margin: 0; padding: 5rpx 48rpx; }

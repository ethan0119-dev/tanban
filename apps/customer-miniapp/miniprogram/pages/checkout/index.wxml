<view class="page" style="{{appearanceStyle}}">
  <view class="card checkout-closed" wx:if="{{store && store.businessStatus !== 'OPEN'}}"><text class="section-title">门店休息中</text><text>{{orderNo ? '这笔订单已在营业时创建，若尚未关闭仍可继续支付。' : (store.businessStatusMessage || '当前不在营业时间，暂时不能提交新订单。')}}</text><text wx:if="{{!orderNo && store.nextOpenAt}}">下次营业：{{store.nextOpenAt}}</text></view>
  <view class="card table-order-card" wx:if="{{tableContext}}"><view><text class="table-badge">堂食桌码</text><text class="section-title">{{tableContext.tableName}}</text><text class="muted">{{tableContext.areaName ? tableContext.areaName + ' · ' : ''}}{{tableContext.storeName}}</text></view><text class="table-code" wx:if="{{tableContext.tableCode}}">{{tableContext.tableCode}}</text><text class="muted">本单将绑定该桌台；如需换桌，请重新扫描新桌码。</text></view>
  <view class="card fast-food-order-card" wx:elif="{{fastFoodContext}}"><view><text class="fast-food-badge">快餐码牌</text><text class="section-title">{{fastFoodContext.plateName}}</text><text class="muted">{{fastFoodContext.storeName}}</text></view><text class="table-code">{{fastFoodContext.plateCode}}</text><text class="muted">本单做好后将放到该码牌指定位置；更换码牌请重新扫码。</text></view>
  <view class="card" wx:else><text class="section-title">取餐方式</text><view class="fulfillment pickup-only"><view class="fulfillment-option active {{detailsLocked ? 'is-locked' : ''}}" role="button" aria-label="门店自取，做好后凭取餐码领取" data-type="PICKUP" bindtap="chooseFulfillment"><text class="fulfillment-title">门店自取</text><text>做好后凭取餐码领取</text></view></view><text class="muted">堂食请扫描桌牌二维码；快餐可扫描商户提供的码牌。</text><text class="muted" wx:if="{{detailsLocked}}">订单已生成，继续支付时将沿用门店自取</text></view>
  <view class="card"><text class="section-title">商品明细</text><view class="line" wx:for="{{cart}}" wx:key="lineKey"><view><text>{{item.name}}</text><text class="muted">{{item.optionSummary || item.skuName || '默认规格'}} × {{item.quantity}}</text></view><text>¥{{item.price * item.quantity / 100}}</text></view><view class="discount-line selectable" wx:if="{{storePromotion}}" bindtap="toggleStorePromotion"><view><text>{{storePromotion.name}}</text><text class="muted">店铺满减 · {{promotionEnabled ? '已自动使用，点击取消' : '已取消，点击恢复'}}</text></view><text class="{{promotionEnabled ? '' : 'disabled-discount'}}">{{promotionEnabled ? '−¥' + promotionDiscountAmount / 100 : '未使用'}}</text></view><view class="discount-line selectable coupon-row" bindtap="openCouponSheet"><view><text>优惠券</text><text class="muted" wx:if="{{eligibleCoupons.length}}">{{eligibleCoupons.length}} 张可用 · 点击选择</text><text class="muted" wx:else>暂无符合本单的优惠券</text></view><text wx:if="{{selectedCoupon}}">−¥{{couponDiscountAmount / 100}} ›</text><text class="muted" wx:else>不使用 ›</text></view><view class="subtotal-line" wx:if="{{discountAmount}}"><text>商品小计</text><text>¥{{subtotalAmount / 100}}</text></view><view class="total"><text>合计</text><text class="price">¥{{amount / 100}}</text></view></view>
  <view class="card order-remark" wx:if="{{!store || !store.orderingSettings || store.orderingSettings.allowOrderRemark}}"><view class="order-remark-heading"><text>订单备注</text><text>{{remark.length || 0}}/500</text></view><textarea value="{{remark}}" disabled="{{detailsLocked}}" auto-height maxlength="500" cursor-spacing="120" show-confirm-bar="{{false}}" placeholder="例如：少冰、打包分装、餐具数量等，可输入多行" bindinput="setRemark" /></view>
  <view class="card contact-field" wx:if="{{store && store.orderingSettings && store.orderingSettings.requireCustomerPhone}}"><text>手机号</text><input type="number" value="{{customerPhone}}" disabled="{{detailsLocked}}" placeholder="用于门店联系您" maxlength="11" bindinput="setCustomerPhone" /></view>
  <view class="card location-hint" wx:if="{{store && store.orderingSettings && store.orderingSettings.distanceCheckEnabled}}"><text>提交时将请求微信定位，仅用于判断是否在门店 {{store.orderingSettings.distanceLimitM}} 米点餐范围内。</text></view>
  <view class="pay-footer"><view><text>实付</text><text class="price">¥{{amount / 100}}</text></view><button class="primary" loading="{{submitting}}" disabled="{{submitting || (store && store.businessStatus !== 'OPEN' && !orderNo)}}" bindtap="submitOrder">{{store && store.businessStatus !== 'OPEN' && !orderNo ? '门店休息中' : (submitting ? '处理中' : (orderNo ? '继续支付' : '提交并支付'))}}</button></view>
</view>
<view class="coupon-sheet-mask" wx:if="{{couponSheetOpen}}" bindtap="closeCouponSheet">
  <view class="coupon-sheet" catchtap="stopCouponSheet">
    <view class="coupon-sheet-header"><text>选择优惠券</text><text bindtap="closeCouponSheet">关闭</text></view>
    <view class="coupon-choice {{!selectedCoupon ? 'selected' : ''}}" data-id="0" bindtap="chooseCoupon"><view><text>不使用优惠券</text><text class="muted">仅使用店铺满减</text></view><text>{{!selectedCoupon ? '✓' : ''}}</text></view>
    <scroll-view scroll-y class="coupon-choice-list">
      <view class="coupon-choice {{selectedCoupon && selectedCoupon.id === item.id ? 'selected' : ''}}" wx:for="{{eligibleCoupons}}" wx:key="id" data-id="{{item.id}}" bindtap="chooseCoupon"><view><text>{{item.name}}</text><text class="muted">{{item.threshold_cents ? '满 ¥' + item.threshold_cents / 100 + ' 可用' : '无门槛'}} · 减 ¥{{item.discount_cents / 100}}</text></view><text>{{selectedCoupon && selectedCoupon.id === item.id ? '✓' : '−¥' + item.discount_cents / 100}}</text></view>
    </scroll-view>
  </view>
</view>
<marketing-popup appearance-style="{{appearanceStyle}}" store-code="{{storeCode}}" placement-code="CHECKOUT_POPUP" channel-scope="{{tableContext ? 'DINE_IN' : 'TAKEOUT'}}" />

.profile-page { min-height: 100vh; padding-bottom: 48rpx; background: var(--paper); }
.profile-hero { padding: 58rpx 38rpx 30rpx; }
.welcome { display: flex; align-items: center; justify-content: space-between; }
.welcome > view { display: flex; flex-direction: column; gap: 24rpx; }
.welcome > view > text:first-child { font-size: var(--font-subtitle); font-weight: var(--font-weight-semibold); }
.welcome .name { max-width: 530rpx; overflow: hidden; font-size: var(--font-display); font-weight: var(--font-weight-semibold); text-overflow: ellipsis; white-space: nowrap; }
.welcome image { width: 104rpx; height: 104rpx; padding: 22rpx; box-sizing: border-box; border-radius: 50%; background: rgba(255,255,255,.75); opacity: .5; }
.asset-summary { display: grid; grid-template-columns: repeat(3, 1fr); margin-top: 48rpx; }
.asset-summary view { display: flex; flex-direction: column; align-items: center; gap: 10rpx; border-right: 1rpx solid rgba(23,32,27,.08); }
.asset-summary view:last-child { border-right: 0; }
.asset-summary text:first-child { font-size: 36rpx; font-weight: var(--font-weight-strong); }
.asset-summary text:last-child { font-size: 25rpx; }
.member-card { display: flex; justify-content: space-between; min-height: 182rpx; margin-top: 42rpx; padding: 34rpx; box-sizing: border-box; border: 1rpx solid var(--card-border); border-radius: var(--radius); color: var(--on-primary); background: var(--green); box-shadow: var(--card-shadow); }
.member-card > view { display: flex; flex-direction: column; gap: 18rpx; }
.member-card > view:first-child text:first-child { font-size: 36rpx; font-weight: var(--font-weight-semibold); }
.member-card > view:first-child text:last-child { color: rgba(255,255,255,.72); font-size: 24rpx; }
.member-card > view:last-child { align-items: flex-end; font-size: 24rpx; }
.service-card { display: grid; grid-template-columns: repeat(3, 1fr); row-gap: 40rpx; margin: 12rpx 24rpx 0; padding: 42rpx 22rpx; border: 1rpx solid var(--card-border); border-radius: var(--radius); background: var(--surface); box-shadow: var(--card-shadow); }
.service-item { display: flex; flex-direction: column; align-items: center; gap: 15rpx; font-size: var(--font-body); }
.service-item image { width: 48rpx; height: 48rpx; }
.version { margin-top: 46rpx; color: #858b85; font-size: 22rpx; text-align: center; }

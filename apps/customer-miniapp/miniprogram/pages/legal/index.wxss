.page { min-height: 100vh; padding: 24rpx; box-sizing: border-box; background: var(--paper); }
.tabs { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; padding: 8rpx; border-radius: 18rpx; background: var(--surface); }
.tabs button { margin: 0; border-radius: var(--button-radius); color: var(--muted); background: transparent; font-size: 26rpx; }
.tabs button::after { border: 0; }
.tabs button.active { color: var(--on-primary); background: var(--green); }
.card { margin-top: 20rpx; padding: 34rpx; border-radius: var(--radius); background: var(--surface); }
.title { display: block; margin-bottom: 28rpx; font-size: 34rpx; font-weight: var(--font-weight-semibold); }
.content { color: var(--ink); font-size: 26rpx; line-height: 1.85; white-space: pre-wrap; }
.loading { padding: 120rpx 0; color: var(--muted); text-align: center; }

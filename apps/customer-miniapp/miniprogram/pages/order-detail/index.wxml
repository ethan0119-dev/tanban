<view class="page" style="{{appearanceStyle}}" wx:if="{{order}}"><view class="{{order.paymentSucceeded ? 'success' : 'payment-waiting'}} card"><view class="check">{{order.paymentSucceeded ? '✓' : '…'}}</view><text class="status-title">{{order.statusTitle}}</text><text class="muted">{{order.paymentSucceeded && order.isDineIn ? '商家已收到订单，请在当前桌台等候' : order.statusMessage}}</text><view class="table-destination" wx:if="{{order.isDineIn}}"><text>堂食桌台</text><text>{{order.displayTableName}}</text><text wx:if="{{order.displayTableArea || order.displayTableCode}}">{{order.displayTableArea}}{{order.displayTableArea && order.displayTableCode ? ' · ' : ''}}{{order.displayTableCode}}</text></view><view class="pickup" wx:else><text>取餐号</text><text>{{order.pickupCode || '--'}}</text></view></view><view class="card"><view class="detail-line"><text>订单号</text><text>{{order.orderNo}}</text></view><view class="detail-line"><text>就餐方式</text><text>{{order.isDineIn ? '堂食 · ' + order.displayTableName : '门店自取'}}</text></view><view class="detail-line"><text>订单状态</text><text class="status">{{order.orderStatusText}}</text></view><view class="detail-line"><text>支付状态</text><text>{{order.paymentStatusText}}</text></view><view class="detail-line"><text>订单金额</text><text class="price">¥{{order.amount / 100}}</text></view><view class="detail-line"><text>下单时间</text><text>{{order.createdAt}}</text></view></view><button class="primary back" bindtap="backToMenu">继续点单</button></view><view class="empty" wx:else>正在确认订单状态…</view>
<marketing-popup appearance-style="{{appearanceStyle}}" wx:if="{{order}}" store-code="{{storeCode}}" placement-code="ORDER_RESULT_POPUP" channel-scope="{{order.isDineIn ? 'DINE_IN' : 'TAKEOUT'}}" />

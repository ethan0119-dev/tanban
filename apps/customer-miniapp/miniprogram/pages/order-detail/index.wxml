<view class="page" wx:if="{{order}}"><view class="success card"><view class="check">✓</view><text class="status-title">{{order.paymentStatus === 'SUCCEEDED' ? '支付成功' : order.status}}</text><text class="muted">商家已收到订单，请留意制作进度</text><view class="pickup"><text>取餐号</text><text>{{order.pickupCode || '--'}}</text></view></view><view class="card"><view class="detail-line"><text>订单号</text><text>{{order.orderNo}}</text></view><view class="detail-line"><text>订单状态</text><text class="status">{{order.status}}</text></view><view class="detail-line"><text>支付状态</text><text>{{order.paymentStatus}}</text></view><view class="detail-line"><text>订单金额</text><text class="price">¥{{order.amount / 100}}</text></view><view class="detail-line"><text>下单时间</text><text>{{order.createdAt}}</text></view></view><button class="primary back" bindtap="backToMenu">继续点单</button></view><view class="empty" wx:else>正在确认订单状态…</view>
